# ---- App ----
APP_ENV=development
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins (frontend URLs)
CORS_ORIGINS=http://localhost:3000

# ---- Supabase project ----
SUPABASE_URL=https://lqcmhzouantgqrxlurhm.supabase.co
# Supabase project ref (used for JWT audience/issuer checks)
SUPABASE_PROJECT_REF=lqcmhzouantgqrxlurhm
# JWT algorithm. Current Supabase projects sign with asymmetric SIGNING KEYS
# (ES256) and publish them via JWKS — this is the default and needs no secret.
# Only older/legacy projects use the shared HS256 "JWT Secret".
# Check which yours uses:
#   curl -s $SUPABASE_URL/auth/v1/.well-known/jwks.json
# If it lists an ES256 key -> ES256. Setting this wrong rejects EVERY real login
# with "The specified alg value is not allowed".
SUPABASE_JWT_ALG=ES256
# JWKS endpoint — used when SUPABASE_JWT_ALG is ES256/RS256 (leave default):
SUPABASE_JWKS_URL=https://lqcmhzouantgqrxlurhm.supabase.co/auth/v1/.well-known/jwks.json
# Only needed when SUPABASE_JWT_ALG=HS256 (legacy projects).
# Get it from: Supabase Dashboard -> Project Settings -> API -> JWT Secret
SUPABASE_JWT_SECRET=

# ---- Database (Supavisor transaction-mode pooler; port 6543) ----
# Get the pooled connection string from:
# Supabase Dashboard -> Project Settings -> Database -> Connection string -> "Transaction" pooler
# Format: postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.lqcmhzouantgqrxlurhm:PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
# Connection pool sizing for THIS process (each container). Keep modest —
# Supavisor multiplexes; total across pods must stay under the project limit.
DB_POOL_MIN=2
DB_POOL_MAX=10
# Search path so unqualified table names resolve to our schema
DB_SCHEMA=mock_db

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Rate limiting ----
RATE_LIMIT_OTP_PER_HOUR=5
RATE_LIMIT_ANSWER_PER_MINUTE=120

# ---- Supabase Storage ----
STORAGE_BUCKET=exam-media
# Signed URL TTL (seconds) for serving question images
SIGNED_URL_TTL=3600
